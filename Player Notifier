-- FUNÇÕES DE MODIFICAÇÃO FÍSICA

local function modificarParte(part)
    if not part:IsA("BasePart") or part.Name == "Terrain" then return end
    
    -- Salvar dados originais
    if not estruturasModificadas[part] then
        estruturasModificadas[part] = {
            OriginalSize = part.Size,
            OriginalCFrame = part.CFrame,
            Path = part:GetFullName()
        }
    end
    
    local original = estruturasModificadas[part].OriginalSize
    
    -- Aplicar modificação FÍSICA
    part.Size = Vector3.new(
        original.X * multiplicadorLargura,
        original.Y * multiplicadorTamanho,
        original.Z * multiplicadorLargura
    )
    
    -- Manter posição central
    part.CFrame = estruturasModificadas[part].OriginalCFrame
end

local function aplicarModificacoes()
    local count = 0
    for _, obj in pairs(workspace:GetDescendants()) do
        if obj:IsA("BasePart") and obj.Name ~= "Terrain" then
            modificarParte(obj)
            count = count + 1
        end
    end
    statusLabel.Text = string.format("💡 Estruturas: %d modificadas", count)
end

local function resetarTudo()
    for part, data in pairs(estruturasModificadas) do
        if part and part.Parent then
            part.Size = data.OriginalSize
            part.CFrame = data.OriginalCFrame
        end
    end
    estruturasModificadas = {}
    statusLabel.Text = "💡 Estruturas: 0 modificadas"
end

-- SISTEMA DE SALVAMENTO

local function salvarEstruturas()
    local dados = {
        largura = multiplicadorLargura,
        tamanho = multiplicadorTamanho,
        timestamp = os.time(),
        estruturas = {}
    }
    
    for part, info in pairs(estruturasModificadas) do
        if part and part.Parent then
            table.insert(dados.estruturas, {
                path = info.Path,
                originalSize = {info.OriginalSize.X, info.OriginalSize.Y, info.OriginalSize.Z}
            })
        end
    end
    
    estruturasSalvas = dados
    
    -- Tentar salvar no GitHub (requer configuração)
    local success, err = pcall(function()
        local json = HttpService:JSONEncode(dados)
        writefile("estruturas_salvas.json", json)
    end)
    
    if success then
        btnSalvar.Text = "✅ SALVO LOCALMENTE!"
        btnSalvar.BackgroundColor3 = Color3.fromRGB(50, 200, 50)
        wait(2)
        btnSalvar.Text = "💾 SALVAR ESTRUTURAS"
        btnSalvar.BackgroundColor3 = Color3.fromRGB(80, 120, 200)
    end
    
    return dados
end

local function carregarEstruturas()
    local success, dados = pcall(function()
        if isfile("estruturas_salvas.json") then
            local json = readfile("estruturas_salvas.json")
            return HttpService:JSONDecode(json)
        end
        return nil
    end)
    
    if success and dados then
        multiplicadorLargura = dados.largura
        multiplicadorTamanho = dados.tamanho
        
        valorLargura.Text = string.format("%.1fx", multiplicadorLargura)
        valorTamanho.Text = string.format("%.1fx", multiplicadorTamanho)
        
        if modificadorAtivo then
            aplicarModificacoes()
        end
        
        btnCarregar.Text = "✅ CARREGADO!"
        btnCarregar.BackgroundColor3 = Color3.fromRGB(50, 200, 50)
        wait(2)
        btnCarregar.Text = "📂 CARREGAR DO GITHUB"
        btnCarregar.BackgroundColor3 = Color3.fromRGB(120, 80, 200)
    else
        btnCarregar.Text = "❌ Nenhum arquivo encontrado"
        wait(2)
        btnCarregar.Text = "📂 CARREGAR DO GITHUB"
    end
end

