-- Função para criar botões
local function criarBotao(texto, posicaoY, cor)
    local botao = Instance.new("TextButton")
    botao.Size = UDim2.new(1, 0, 0, 45)
    botao.Position = UDim2.new(0, 0, 0, posicaoY)
    botao.BackgroundColor3 = cor or Color3.fromRGB(40, 40, 45)
    botao.Text = texto
    botao.TextColor3 = Color3.fromRGB(255, 255, 255)
    botao.TextSize = 14
    botao.Font = Enum.Font.GothamSemibold
    botao.BorderSizePixel = 0
    botao.AutoButtonColor = false
    botao.Parent = container
    
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 8)
    corner.Parent = botao
    
    -- Efeito hover
    botao.MouseEnter:Connect(function()
        botao.BackgroundColor3 = Color3.fromRGB(
            math.min(255, botao.BackgroundColor3.R * 255 + 20),
            math.min(255, botao.BackgroundColor3.G * 255 + 20),
            math.min(255, botao.BackgroundColor3.B * 255 + 20)
        )
    end)
    
    botao.MouseLeave:Connect(function()
        botao.BackgroundColor3 = cor or Color3.fromRGB(40, 40, 45)
    end)
    
    return botao
end

